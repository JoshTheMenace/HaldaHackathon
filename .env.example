# Copy to .env.local and fill in your own key. .env.local is gitignored.
# Get a key at https://aistudio.google.com/apikey

# Server-side (text agent, /api/gemini). Required.
GEMINI_API_KEY=your-google-ai-studio-key

# Client-side (browser Gemini Live voice). Required for voice mode.
# NOTE: NEXT_PUBLIC_* is embedded in the browser bundle at build time and is
# therefore visible to anyone using a deployed build. Use a restricted key and
# rotate it regularly; for production, mint ephemeral tokens instead.
NEXT_PUBLIC_GEMINI_API_KEY=your-google-ai-studio-key

# Optional model overrides (defaults shown).
# GEMINI_TEXT_MODEL=gemini-3.5-flash
# NEXT_PUBLIC_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
